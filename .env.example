# Copie este arquivo para .env e preencha com os valores reais.
# O .env NÃO é versionado (está no .gitignore).

# Chave secreta do Flask (sessões). Gere uma com:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=cole_aqui_um_token_hex_de_64_caracteres

# Chave da API do RAWG (https://rawg.io/apidocs) para busca de jogos.
RAWG_KEY=0123456789abcdef0123456789abcdef

# URL do backend FastAPI.
API_FASTAPI=http://127.0.0.1:8000

# Porta do servidor Flask (no macOS use 5001 por causa do AirPlay).
PORT=5001
